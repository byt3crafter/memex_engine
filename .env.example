# PantryMind configuration
# Copy this file to `.env` and fill values. `.env` is gitignored.

# HTTP server port for apps/api (default: 8787)
HEALTHLOOP_PORT=8787

# libSQL / SQLite connection string.
# Local file:   file:./data/pantrymind.db
# Remote libsql: libsql://<host>?authToken=<token>
HEALTHLOOP_DATABASE_URL=file:./data/pantrymind.db

# Bearer token required by all /api/v1/* requests.
# Generate one with:  openssl rand -hex 32
HEALTHLOOP_API_TOKEN=replace-me-with-a-strong-token

# Public base URL the API is reachable at (used in OpenAPI servers + docs).
HEALTHLOOP_BASE_URL=http://localhost:8787

# IANA timezone string, used when interpreting "today" / dates.
HEALTHLOOP_DEFAULT_TIMEZONE=Indian/Mauritius
