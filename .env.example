# Memex configuration
# Copy this file to `.env` and fill values. `.env` is gitignored.

# HTTP server port for apps/api (default: 8787)
MEMEX_PORT=8787

# libSQL / SQLite connection string.
# Local file:    file:./data/memex.db
# Remote libsql: libsql://<host>?authToken=<token>
MEMEX_DATABASE_URL=file:./data/memex.db

# Bootstrap admin token. Used ONCE on first start to create the founder
# user and issue the first pairing code, then for /admin endpoints. Treat
# as a root credential; rotate after the founder user is provisioned.
# Generate with: openssl rand -hex 32
MEMEX_BOOTSTRAP_TOKEN=replace-me-with-a-strong-token-at-least-32-hex-chars

# Public base URL the kernel is reachable at (used in OpenAPI servers,
# pairing QR payloads, and assistant config snippets).
MEMEX_BASE_URL=http://localhost:8787

# IANA timezone string used as a default for new users (each user can
# override their own).
MEMEX_DEFAULT_TIMEZONE=Indian/Mauritius

# Modules to enable (comma-separated). Defaults to all installed.
# Example: MEMEX_MODULES=demeter,hypnos
MEMEX_MODULES=demeter

# Log level: fatal | error | warn | info | debug | trace
MEMEX_LOG_LEVEL=info
