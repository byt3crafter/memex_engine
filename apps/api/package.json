{
  "name": "@pantrymind/api",
  "version": "0.0.0-pre",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:api": "vitest run",
    "test:e2e": "echo 'demo:dry-run lands in Phase 2' && exit 0",
    "demo:dry-run": "echo 'demo:dry-run lands in Phase 2' && exit 0",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@pantrymind/core": "workspace:*",
    "@pantrymind/db": "workspace:*",
    "@pantrymind/schemas": "workspace:*",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
