{
  "name": "@pantrymind/core",
  "version": "0.0.0-pre",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./services": "./src/services/index.ts",
    "./cards": "./src/cards/index.ts",
    "./util": "./src/util/index.ts",
    "./test-support": "./src/test-support/index.ts"
