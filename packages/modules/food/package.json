{
  "name": "@memex/module-food",
  "version": "0.1.0",
  "description": "Demeter — pantry, meals, recipes, menus, and the outcome-aware recommendation engine. The first Memex module.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "generate": "drizzle-kit generate --config=drizzle.config.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@huggingface/transformers": "^4.2.0",
    "@libsql/client": "^0.14.0",
    "@memex/db": "workspace:*",
    "@memex/kernel": "workspace:*",
    "@memex/schemas": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
